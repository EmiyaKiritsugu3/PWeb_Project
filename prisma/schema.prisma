generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Funcionario {
  id           String   @id @default(dbgenerated("gen_random_uuid()"))
  nomeCompleto String
  email        String   @unique
  role         Role     @default(RECEPCIONISTA)
  Treinos      Treino[]

  @@map("funcionarios")
}

model Aluno {
  id                 String            @id @default(dbgenerated("gen_random_uuid()"))
  nomeCompleto       String
  cpf                String            @unique
  email              String            @unique
  telefone           String?
  dataNascimento     DateTime?
  dataCadastro       DateTime          @default(now())
  fotoUrl            String?
  biometriaHash      String?           @unique
  statusMatricula    StatusAluno       @default(ATIVA)
  nivel              Int               @default(1)
  exp                Int               @default(0)
  streakDiasSeguidos Int               @default(0)
  treinosNoMes       Int               @default(0)
  ultimoTreinoData   DateTime?
  HistoricoTreinos   HistoricoTreino[]
  Matriculas         Matricula[]
  Pagamentos         Pagamento[]
  Treinos            Treino[]

  @@map("alunos")
}

model Plano {
  id          String      @id @default(dbgenerated("gen_random_uuid()"))
  nome        String
  preco       Float
  duracaoDias Int
  Matriculas  Matricula[]

  @@map("planos")
}

model Matricula {
  id             String          @id @default(dbgenerated("gen_random_uuid()"))
  alunoId        String
  planoId        String
  dataInicio     DateTime        @default(now())
  dataVencimento DateTime
  status         StatusMatricula @default(ATIVA)
  Aluno          Aluno           @relation(fields: [alunoId], references: [id])
  Plano          Plano           @relation(fields: [planoId], references: [id])
  Pagamentos     Pagamento[]

  @@index([alunoId])
  @@index([status])
  @@map("matriculas")
}

model Pagamento {
  id            String          @id @default(dbgenerated("gen_random_uuid()"))
  matriculaId   String
  alunoId       String
  valor         Float
  dataPagamento DateTime        @default(now())
  metodo        MetodoPagamento
  Aluno         Aluno           @relation(fields: [alunoId], references: [id])
  Matricula     Matricula       @relation(fields: [matriculaId], references: [id])

  @@index([alunoId])
  @@index([dataPagamento])
  @@map("pagamentos")
}

model Treino {
  id               String            @id @default(dbgenerated("gen_random_uuid()"))
  alunoId          String
  instrutorId      String?
  objetivo         String
  dataCriacao      DateTime          @default(now())
  diaSemana        Int?
  Exercicios       Exercicio[]
  HistoricoTreinos HistoricoTreino[]
  Aluno            Aluno             @relation(fields: [alunoId], references: [id])
  Instrutor        Funcionario?      @relation(fields: [instrutorId], references: [id])

  @@index([alunoId])
  @@map("treinos")
}

model Exercicio {
  id            String  @id @default(dbgenerated("gen_random_uuid()"))
  treinoId      String
  nomeExercicio String
  series        Int
  repeticoes    String
  observacoes   String?
  descricao     String?
  Treino        Treino  @relation(fields: [treinoId], references: [id], onDelete: Cascade)

  @@map("exercicios")
}

model HistoricoTreino {
  id               String           @id @default(dbgenerated("gen_random_uuid()"))
  alunoId          String
  treinoId         String
  dataExecucao     DateTime         @default(now())
  duracaoMinutos   Int
  Aluno            Aluno            @relation(fields: [alunoId], references: [id])
  Treino           Treino           @relation(fields: [treinoId], references: [id])
  SeriesExecutadas SerieExecutada[]

  @@index([alunoId, dataExecucao])
  @@map("historico_treinos")
}

model SerieExecutada {
  id                String          @id @default(dbgenerated("gen_random_uuid()"))
  historicoTreinoId String
  exercicioId       String
  nomeExercicio     String
  serieNumero       Int
  peso              Float?
  repeticoesFeitas  Int?
  concluido         Boolean         @default(false)
  HistoricoTreino   HistoricoTreino @relation(fields: [historicoTreinoId], references: [id], onDelete: Cascade)

  @@index([historicoTreinoId])
  @@map("series_executadas")
}

enum Role {
  GERENTE
  RECEPCIONISTA
  INSTRUTOR
}

enum StatusAluno {
  ATIVA
  INADIMPLENTE
  INATIVA
}

enum StatusMatricula {
  ATIVA
  VENCIDA
}

enum MetodoPagamento {
  PIX
  DINHEIRO
  CARTAO
}
