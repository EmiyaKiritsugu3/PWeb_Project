generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Funcionario {
  id           String   @id @default(uuid())
  nomeCompleto String
  email        String   @unique
  role         Role     @default(RECEPCIONISTA)
  
  Treinos      Treino[]
}

enum Role {
  GERENTE
  RECEPCIONISTA
  INSTRUTOR
}

model Aluno {
  id              String      @id @default(uuid())
  nomeCompleto    String
  cpf             String      @unique
  email           String      @unique
  telefone        String?
  dataNascimento  DateTime?
  dataCadastro    DateTime    @default(now())
  fotoUrl         String?
  biometriaHash   String?     @unique
  statusMatricula StatusAluno @default(ATIVA)

  Matriculas Matricula[]
  Pagamentos Pagamento[]
  Treinos    Treino[]
}

enum StatusAluno {
  ATIVA
  INADIMPLENTE
  INATIVA
}

model Plano {
  id          String      @id @default(uuid())
  nome        String
  preco       Float
  duracaoDias Int
  
  Matriculas  Matricula[]
}

model Matricula {
  id             String         @id @default(uuid())
  alunoId        String
  planoId        String
  dataInicio     DateTime       @default(now())
  dataVencimento DateTime
  status         StatusMatricula @default(ATIVA)

  Aluno      Aluno       @relation(fields: [alunoId], references: [id])
  Plano      Plano       @relation(fields: [planoId], references: [id])
  Pagamentos Pagamento[]
}

enum StatusMatricula {
  ATIVA
  VENCIDA
}

model Pagamento {
  id            String          @id @default(uuid())
  matriculaId   String
  alunoId       String
  valor         Float
  dataPagamento DateTime        @default(now())
  metodo        MetodoPagamento

  Matricula Matricula @relation(fields: [matriculaId], references: [id])
  Aluno     Aluno     @relation(fields: [alunoId], references: [id])
}

enum MetodoPagamento {
  PIX
  DINHEIRO
  CARTAO
}

model Treino {
  id          String   @id @default(uuid())
  alunoId     String
  instrutorId String?
  objetivo    String
  dataCriacao DateTime @default(now())
  diaSemana   Int?

  Aluno       Aluno       @relation(fields: [alunoId], references: [id])
  Instrutor   Funcionario? @relation(fields: [instrutorId], references: [id])
  Exercicios  Exercicio[]
}

model Exercicio {
  id            String  @id @default(uuid())
  treinoId      String
  nomeExercicio String
  series        Int
  repeticoes    String
  observacoes   String?
  descricao     String?

  Treino Treino @relation(fields: [treinoId], references: [id], onDelete: Cascade)
}
