{
  "name": "nextn",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "genkit:dev": "genkit start -- tsx src/ai/dev.ts",
    "genkit:watch": "genkit start -- tsx --watch src/ai/dev.ts",
    "build": "NODE_ENV=production next build",
    "start": "next start",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate",
    "prepare": "husky",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "e2e": "dotenv -e .env.test -- playwright test",
    "e2e:ui": "dotenv -e .env.test -- playwright test --ui",
    "e2e:report": "playwright show-report",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "seed:e2e": "dotenv -e .env.test -- tsx prisma/seed-e2e.ts",
    "pre-flight": "npm run typecheck && npm run lint && npm run format:check && npm run test",
    "protocol:plan": "tsx scripts/sentinel-cli.ts plan",
    "sentinel": "tsx scripts/sentinel-cli.ts",
    "db:check": "tsx scripts/check-db.ts",
    "db:create-user": "tsx scripts/create-test-user.ts"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,yml,yaml,md,css,mjs,cjs}": [
      "prettier --write"
    ]
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@genkit-ai/google-genai": "^1.32.0",
    "@genkit-ai/next": "^1.32.0",
    "@hookform/resolvers": "^5.4.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/sdk-trace-base": "^2.7.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.0",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
