    "genkit": "^1.32.0",
    "inquirer": "^13.4.1",
    "lodash": "^4.18.1",
    "lucide-react": "^1.16.0",
    "mongodb": "^7.2.0",
    "motion": "^12.38.0",
    "next": "^15.5.15",
    "patch-package": "^8.0.1",
    "pg": "^8.20.0",
    "react": "^19.2.5",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.5",
