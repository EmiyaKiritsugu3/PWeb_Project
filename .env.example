# ==============================================================================
# PWeb Project - Template de Configuração de Ambiente
# ==============================================================================
# INSTRUÇÕES:
# 1. Copie este arquivo para um novo arquivo chamado '.env.local'
# 2. Preencha os valores reais no '.env.local'
# 3. NUNCA envie o '.env.local' ou qualquer arquivo com chaves reais para o Git.
# ==============================================================================

# ------------------------------------------------------------------------------
# 🤖 Provedores de IA (Server-side Only)
# ------------------------------------------------------------------------------

# Google Gemini / GenAI (Principal)
# Obtenha em: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Anthropic (Claude)
# Obtenha em: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# DeepSeek
# Obtenha em: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# OpenRouter (Acesso a múltiplos modelos)
# Obtenha em: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ------------------------------------------------------------------------------
# 🛠️ Ferramentas de Desenvolvimento e Busca
# ------------------------------------------------------------------------------

# Context7 (Documentação e Skills)
# Obtenha em: https://context7.com/dashboard
CONTEXT7_API_KEY=

# Exa Search (Busca semântica)
# Obtenha em: https://exa.ai/
EXA_API_KEY=

# ------------------------------------------------------------------------------
# ⚡ Supabase & Banco de Dados
# ------------------------------------------------------------------------------

# Configurações Públicas (Podem ter o prefixo NEXT_PUBLIC_)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Configurações Privadas (Apenas Servidor)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Prisma (Conexão direta e pooler)
# Use o modo 'Transaction' para DATABASE_URL e 'Session' para DIRECT_URL no Supabase
DATABASE_URL="postgresql://postgres:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"

# ------------------------------------------------------------------------------
# 📈 Monitoramento e Observabilidade
# ------------------------------------------------------------------------------

# Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ENVIRONMENT=development

# ------------------------------------------------------------------------------
# 🚀 Infraestrutura e Deploy
# ------------------------------------------------------------------------------

# Vercel
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# GitHub (CI/CD e Automação)
GITHUB_TOKEN=

# ------------------------------------------------------------------------------
# ⚙️ Configurações da Aplicação
# ------------------------------------------------------------------------------

NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ⚠️ ADICIONE SUAS CHAVES CUSTOMIZADAS ABAIXO DESTA LINHA
